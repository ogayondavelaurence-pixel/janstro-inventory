# ============================================================================
# JANSTRO IMS - XAMPP Development .htaccess
# ============================================================================
# Path: public/.htaccess
# For: Local development on Windows XAMPP
# ============================================================================

# Enable URL rewriting
RewriteEngine On
RewriteBase /janstro-inventory/public/

# Route all API requests to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Security: Block access to sensitive files
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

<FilesMatch "^\.git">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|bak)$">
    Require all denied
</FilesMatch>

# Disable directory browsing
Options -Indexes

# Security headers (if mod_headers is enabled)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# PHP settings for development
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log ../logs/php-error.log
</IfModule>

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT:
# - Replace this file with deployment/.htaccess.production
# - Enable HTTPS redirects
# - Add full security headers
# - Configure proper CORS policies
# ============================================================================