# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME="Janstro IMS"
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost:8080/janstro-inventory
FRONTEND_URL=http://localhost:8080/janstro-inventory/frontend

# ============================================================================
# DATABASE CONFIGURATION (CRITICAL)
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=janstro_inventory
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ============================================================================
# SECURITY SETTINGS (CRITICAL FIX)
# ============================================================================

# JWT Settings (all in SECONDS)
JWT_SECRET=janstro_inventory_secret_key_2025_change_in_production
JWT_EXPIRATION=86400
JWT_ALGORITHM=HS256
JWT_REFRESH_EXPIRATION=604800

# ✅ FIXED: Session lifetime in SECONDS (24 hours)
SESSION_LIFETIME=86400

SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

ENCRYPTION_KEY=janstro_encryption_key_32chars

# ============================================================================
# RATE LIMITING & SECURITY
# ============================================================================
RATE_LIMIT_ENABLED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900
API_RATE_LIMIT=100

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=false

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=janstroprimecorporation@gmail.com
MAIL_PASSWORD=faasyndlijrwtonk
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=janstroprimecorporation@gmail.co
MAIL_FROM_NAME=Janstro Prime IMS

# ============================================================================
# FILE UPLOAD SETTINGS
# ============================================================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,xlsx,csv
UPLOAD_PATH=C:/xampp/htdocs/janstro-inventory/storage/uploads

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_ENABLED=true
BACKUP_PATH=C:/xampp/htdocs/janstro-inventory/backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# ============================================================================
# LOGGING SETTINGS
# ============================================================================
LOG_LEVEL=debug
LOG_PATH=C:/xampp/htdocs/janstro-inventory/logs
LOG_MAX_SIZE=10485760
LOG_RETENTION_DAYS=90

ERROR_REPORTING=true
ERROR_LOG_FILE=error.log

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================
NOTIFICATIONS_ENABLED=true

LOW_STOCK_ALERT_ENABLED=true
LOW_STOCK_CHECK_SCHEDULE=0 9 * * *
LOW_STOCK_RECIPIENTS=admin@janstro.com

ORDER_NOTIFICATION_ENABLED=true
ORDER_NOTIFICATION_RECIPIENTS=orders@janstro.com

DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_SCHEDULE=0 18 * * *
DAILY_SUMMARY_RECIPIENTS=management@janstro.com

# ============================================================================
# COMPANY INFORMATION
# ============================================================================
COMPANY_NAME="Janstro Prime Corporation"
COMPANY_ADDRESS="Majayjay, Calabarzon, Philippines"
COMPANY_PHONE="+63-999 759 4616"
COMPANY_EMAIL="janstroprime@gmail.com"
COMPANY_WEBSITE="https://janstrosolar.wixsite.com/website

